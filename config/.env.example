# copy this file to .env and fill in your own values

# local mosquitto settings (espresense connects to this)
LOCAL_MQTT_HOST=192.168.1.50
LOCAL_MQTT_PORT=1883
LOCAL_MQTT_USERNAME=username
LOCAL_MQTT_PASSWORD=12345
LOCAL_MQTT_TOPIC=espresense/devices/#

# aws iot core endpoint and tls port
AWS_IOT_ENDPOINT=replace-this-with-your-aws-endpoint-ats.iot.us-east-1.amazonaws.com
AWS_IOT_PORT=8883

# full file paths to your aws cert files
# use forward slashes on windows to keep paths simple
AWS_ROOT_CA_PATH=C:/aws-iot/AmazonRootCA1.pem
AWS_CERT_PATH=C:/aws-iot/device-certificate.pem.crt
AWS_PRIVATE_KEY_PATH=C:/aws-iot/device-private.pem.key

# mosquitto files
MOSQUITTO_PASSWORD_FILE_PATH=C:/mosquitto/config/passwords.txt
MOSQUITTO_OUTPUT_CONF_PATH=C:/mosquitto/config/bridge-espresense.conf
MOSQUITTO_BRIDGE_NAME=espresense_to_aws

# optional values used by sample scripts
ESPRESENSE_ROOM=office
ESPRESENSE_SCANNER_ID=esp32_office
SAMPLE_BLE_MAC=AA:BB:CC:DD:EE:FF